# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REVIEW_MODEL=gpt-5.4
RECIPE_OCR_MODEL=gpt-5.4-mini
RECIPE_CLEANUP_MODEL=gpt-5.4

# Storage configuration
# For a sanitized local demo, run scripts\seed_demo_data.py and set DB_PATH=demo.db.
DB_PATH=projects.db
UPLOADS_DIR=uploads
# Set this on a public demo deployment. It adds demo banners and disables Codex worker polling.
# DEMO_MODE=1
# Optional Cloud Run persistence backing store
# GCS_BUCKET=your-project-dieter-data
# GCS_PREFIX=dieter
# Optional invite code required for new accounts
# DIETER_REGISTRATION_CODE=change-this-before-deploy

# Strava OAuth for Dieter Trainer
# Create an app at https://www.strava.com/settings/api
# STRAVA_CLIENT_ID=your-strava-client-id
# STRAVA_CLIENT_SECRET=your-strava-client-secret
# Optional; set this if Cloud Run/proxy URL inference does not match the registered callback
# STRAVA_REDIRECT_URI=https://askdieter.ai/apps/trainer/strava/callback

# Spotify OAuth for Dieter Music
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# SPOTIFY_REDIRECT_URI=http://localhost:8000/apps/music/playlists/spotify/callback

# Optional Studio external project routing for the local Codex worker
# EEG_REPO_PATH=C:\Users\curti\repos\eeg_headband
# CALCIUM_IMAGING_REPO_PATH=C:\Users\curti\repos\calcium_imaging

# Alternative: Use Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
